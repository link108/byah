---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About"
  description="Longer bio and background."
  currentPath="/about"
>
  <section class="content-body">
    <span class="eyebrow">About</span>
    <h1>Longer Bio</h1>
    <p>
      I build things and follow ideas wherever they go — usually software or
      hardware, but not always.
    </p>
    <p>
      I’m interested in technology, art, and philosophy, and how they show up in
      the things I make.
    </p>
    <p>
      This site is a collection of projects, notes, and experiments along the way.
    </p>
  </section>
</BaseLayout>
